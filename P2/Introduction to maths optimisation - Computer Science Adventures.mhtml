<div class=3D"clipboard-copy-txt" id=3D"cell-5"># Create array of x samples
xmin, xmax, nx =3D -4, 4, 41
tab_x =3D np.linspace(xmin,xmax,nx)
# Calculate values of f(x,y) for x values in tab_x and different y values
tab_zm2 =3D f1(tab_x,-2)
tab_z0 =3D f1(tab_x,0)
tab_zp2 =3D f1(tab_x,2)
# Plot the graph
plt.plot(tab_x, tab_zm2,'k-',label=3D'y =3D -2')
plt.plot(tab_x, tab_z0,'r-',label=3D'y =3D 0')
plt.plot(tab_x, tab_zp2,'b-',label=3D'y =3D +2')
plt.xlabel('x values')
plt.ylabel('f1(x,y=3Dconstant) values')
plt.legend()
plt.grid()</div>
