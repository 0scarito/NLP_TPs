<div class=3D"clipboard-copy-txt" id=3D"cell-6"># Create array of y samples
ymin, ymax, ny =3D -4, 4, 41
tab_y =3D np.linspace(ymin,ymax,ny)
# Calculate values of f(x,y) for y values in tab_y and different x values
tab_zm2 =3D f1(-2,tab_y)
tab_z0 =3D f1(0,tab_y)
tab_zp2 =3D f1(2,tab_y)
# Plot the graph
plt.plot(tab_y, tab_zm2,'k-',label=3D'x =3D -2')
plt.plot(tab_y, tab_z0,'r-',label=3D'x =3D 0')
plt.plot(tab_y, tab_zp2,'b-',label=3D'x =3D +2')
plt.xlabel('y values')
plt.ylabel('f1(x=3Dconstant,y) values')
plt.legend()
plt.grid()

