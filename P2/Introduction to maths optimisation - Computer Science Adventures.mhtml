<div class=3D"clipboard-copy-txt" id=3D"cell-8"># Definition of the plottin=
g domain
xmin, xmax, nx =3D -4, 4, 41
ymin, ymax, ny =3D -4, 4, 41
# Discretization of the plotting domain
x1d =3D np.linspace(xmin,xmax,nx)
y1d =3D np.linspace(ymin,ymax,ny)
x2d, y2d =3D np.meshgrid(x1d, y1d)

# Plot contour lines (isovalues) of f1
nIso =3D 21
plt.contour(x2d,y2d,f1(x2d,y2d),nIso)
plt.title('Contour Lines')
plt.xlabel('x values')
plt.ylabel('y values')
plt.grid()
plt.axis('square')</div>
