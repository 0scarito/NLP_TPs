<div class=3D"clipboard-copy-txt" id=3D"cell-53">fig, axes =3D plt.subplots=
(2, 3, figsize=3D(7,5))
axes =3D axes.flatten()
cmaps =3D ["Greys", "Blues", "Oranges", "Reds", "Purples", "Greens"]
labels =3D emotions["train"].features["label"].names

for i, (label, cmap) in enumerate(zip(labels, cmaps)):
    df_emb_sub =3D df_emb.query(f"label =3D=3D {i}")
    axes[i].hexbin(df_emb_sub["X"], df_emb_sub["Y"], cmap=3Dcmap,
                   gridsize=3D20, linewidths=3D(0,))
    axes[i].set_title(label)
    axes[i].set_xticks([]), axes[i].set_yticks([])

plt.tight_layout()
plt.show()</div>
