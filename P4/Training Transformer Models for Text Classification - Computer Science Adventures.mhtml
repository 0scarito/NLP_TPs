<div class=3D"clipboard-copy-txt" id=3D"cell-57">from sklearn.metrics impor=
t ConfusionMatrixDisplay, confusion_matrix

def plot_confusion_matrix(y_preds, y_true, labels):
    cm =3D confusion_matrix(y_true, y_preds, normalize=3D"true")
    fig, ax =3D plt.subplots(figsize=3D(6, 6))
    disp =3D ConfusionMatrixDisplay(confusion_matrix=3Dcm, display_labels=
=3Dlabels)
    disp.plot(cmap=3D"Blues", values_format=3D".2f", ax=3Dax, colorbar=3DFa=
lse)
    plt.title("Normalized confusion matrix")
    plt.show()
   =20
y_preds =3D lr_clf.predict(X_valid)
plot_confusion_matrix(y_preds, y_valid, labels)</div>
