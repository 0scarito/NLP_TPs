<div class=3D"clipboard-copy-txt" id=3D"cell-59">from sklearn.metrics impor=
t accuracy_score, f1_score

def compute_metrics(pred):
    labels =3D pred.label_ids
    preds =3D pred.predictions.argmax(-1)
    f1 =3D f1_score(labels, preds, average=3D"weighted")
    acc =3D accuracy_score(labels, preds)
    return {"accuracy": acc, "f1": f1}</div>
