<div class=3D"clipboard-copy-txt" id=3D"cell-52">from umap import UMAP
from sklearn.preprocessing import MinMaxScaler

# Scale features to [0,1] range
X_scaled =3D MinMaxScaler().fit_transform(X_train)
# Initialize and fit UMAP
mapper =3D UMAP(n_components=3D2, metric=3D"cosine").fit(X_scaled)
# Create a DataFrame of 2D embeddings
df_emb =3D pd.DataFrame(mapper.embedding_, columns=3D["X", "Y"])
df_emb["label"] =3D y_train
df_emb.head()</div>
